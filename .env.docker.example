# ==============================================================================
# Flow-IO — Docker / Self-Hosting Environment
# ==============================================================================
# Copy this file to .env.docker and fill in your values.
#
#   cp .env.docker.example .env.docker
#
# The Supabase keys below are the official demo defaults that work together
# out of the box. For any internet-facing deployment you MUST replace them:
#   https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# ==============================================================================

# ------------------------------------------------------------------------------
# Postgres
# ------------------------------------------------------------------------------
POSTGRES_PASSWORD=your-super-secret-postgres-password

# ------------------------------------------------------------------------------
# Supabase JWT
# These three values must match. The ANON_KEY and SERVICE_ROLE_KEY below are
# the official Supabase demo JWTs signed with the JWT_SECRET above.
# Regenerate all three together for production!
# ------------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

# Demo keys — valid only with the demo JWT_SECRET above
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7W9oraprfDjS5sm9nu6-qameTa16rosRmsc
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SBc0

# ------------------------------------------------------------------------------
# Supabase Studio dashboard login
# ------------------------------------------------------------------------------
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=change-me-please

# ------------------------------------------------------------------------------
# URLs
# For local: leave as-is.
# For a server: set to your public domain, e.g. https://flow-io.example.com
# ------------------------------------------------------------------------------
SITE_URL=http://localhost:3000
API_EXTERNAL_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Additional OAuth redirect URLs (comma-separated, optional)
ADDITIONAL_REDIRECT_URLS=

# ------------------------------------------------------------------------------
# Auth settings
# ------------------------------------------------------------------------------
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
# Set to true to skip email confirmation (convenient for self-hosted installs)
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false

# ------------------------------------------------------------------------------
# sipgate OAuth
# Register your app at: https://console.sipgate.com/third-party-clients
# Set redirect URI to: http://localhost:3000/api/auth/sipgate/callback
# ------------------------------------------------------------------------------
SIPGATE_OAUTH_CLIENT_ID=your-sipgate-oauth-client-id
SIPGATE_OAUTH_CLIENT_SECRET=your-sipgate-oauth-client-secret

# ------------------------------------------------------------------------------
# Email / SMTP (optional — leave blank to use the built-in Inbucket test inbox)
# Inbucket web UI is available at http://localhost:54324
# ------------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=noreply@example.com
SMTP_SENDER_NAME=Flow-IO

# ------------------------------------------------------------------------------
# LLM Providers (at least one required)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-your-openai-key-here
GOOGLE_AI_API_KEY=
MISTRAL_API_KEY=

# ------------------------------------------------------------------------------
# ElevenLabs (required for TTS)
# ------------------------------------------------------------------------------
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# ------------------------------------------------------------------------------
# sipgate AI Flow
# ------------------------------------------------------------------------------
SIPGATE_WEBHOOK_SECRET=your-random-webhook-secret-here
# SIPGATE_API_KEY=your-sipgate-pat-here  # optional PAT

# ------------------------------------------------------------------------------
# Optional: restrict signups to one email domain
# ------------------------------------------------------------------------------
# SIGNUP_ALLOWED_EMAIL_DOMAIN=company.com

# ------------------------------------------------------------------------------
# Ports (change if you have conflicts)
# ------------------------------------------------------------------------------
APP_PORT=3000
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
