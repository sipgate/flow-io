# ==============================================================================
# Flow-IO - Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in your actual values.
# Never commit .env.local to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Supabase
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------------------------------------------
# LLM Providers (at least one is required)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-your-openai-key-here
GOOGLE_AI_API_KEY=your-google-ai-key-here
MISTRAL_API_KEY=your-mistral-api-key-here

# ------------------------------------------------------------------------------
# ElevenLabs (required for TTS and phoneme preview)
# Get your key from: https://elevenlabs.io/app/settings/api-keys
# ------------------------------------------------------------------------------
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# ------------------------------------------------------------------------------
# sipgate
# OAuth: register your app at https://console.sipgate.com/third-party-clients
# Webhook secret: shared with sipgate's webhook settings for HMAC-SHA256 verification.
#   If omitted, signature verification is skipped (not recommended for production).
# API key (PAT): optional, used as fallback for server-side operations.
#   WARNING: PATs grant full account access. Never commit or expose client-side.
# ------------------------------------------------------------------------------
SIPGATE_OAUTH_CLIENT_ID=your-sipgate-oauth-client-id
SIPGATE_OAUTH_CLIENT_SECRET=your-sipgate-oauth-client-secret
SIPGATE_WEBHOOK_SECRET=your-random-webhook-secret-here
# SIPGATE_API_KEY=your-sipgate-pat-here  # optional

# ------------------------------------------------------------------------------
# Application
# Public URL used for OAuth redirects and email links
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Optional: restrict signups to a single email domain (e.g. "company.com").
# Leave unset to allow signups from any email address.
# ------------------------------------------------------------------------------
# SIGNUP_ALLOWED_EMAIL_DOMAIN=company.com

# ------------------------------------------------------------------------------
# Redis (optional — only needed for background job processing)
# ------------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379
